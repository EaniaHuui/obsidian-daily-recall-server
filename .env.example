PORT=8080
BASE_URL=https://your-domain.com
DB_PATH=/data/recall.db

# 32-byte hex key for AES-256-GCM encrypted user secrets.
MASTER_KEY=replace-with-64-hex-characters

JWT_SECRET=replace-with-random-secret
JWT_EXPIRE_DAYS=30

DEFAULT_AI_BASE_URL=https://api.deepseek.com/v1
DEFAULT_AI_KEY=
DEFAULT_AI_MODEL=deepseek-chat
DEFAULT_AI_DAILY_LIMIT=1

RATE_LIMIT_LOGIN=5
RATE_LIMIT_SYNC=10

